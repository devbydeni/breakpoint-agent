# --- AI (optional but recommended) ---
# Google Gemini API key. Without it, analyses still run in deterministic mode
# but AI narratives, executive summaries, and chat are disabled.
GEMINI_API_KEY=your-gemini-api-key-here

# --- REST API server ---
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Optional API-key auth for the REST API. When set, every /api request must
# send "x-api-key: <key>" or "Authorization: Bearer <key>". Comma-separate to
# allow multiple keys. Leave blank to keep the API open (local development).
API_KEY=

# --- Telegram bot ---
# Token from @BotFather. Required only when running `npm run bot`.
TELEGRAM_BOT_TOKEN=
